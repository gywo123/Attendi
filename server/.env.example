PORT=4000
CLIENT_URL=http://localhost:5173
JWT_SECRET=change-this-local-secret
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/attendi?retryWrites=true&w=majority
DB_NAME=attendi

# Local development convenience. Set to false when testing real school GPS rules.
DEV_BYPASS_LOCATION=true

# Set to false when you want a completely empty SQLite DB without demo seed data.
SEED_DEMO_DATA=true

# School GPS center. Replace with the real school coordinates.
SCHOOL_NAME=학교
SCHOOL_LATITUDE=37.2538509301
SCHOOL_LONGITUDE=126.9823507279
SCHOOL_RADIUS_METERS=100

# Google OAuth Web client settings.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
